{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Glob(*)",
      "Grep(*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(jq *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Read(~/.zshrc)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote -v)",
      "Bash(git blame *)",
      "Bash(git stash list)",
      "Bash(git rev-parse *)",
      "Bash(git fetch *)",
      "Bash(git pull --ff-only*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(PYTHONPATH=*)",
      "Bash(npm run *)",
      "Bash(pnpm run *)",
      "Bash(pnpm build *)",
      "Bash(yarn *)",
      "Bash(uv add *)",
      "Bash(uv pip *)",
      "Bash(uv run *)",
      "Bash(uv sync*)",
      "Bash(uv lock*)",
      "Bash(uvx *)",
      "Bash(python -c *)",
      "Bash(python -m *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m *)",
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(mypy *)",
      "Bash(bazel *)",
      "Bash(tmux *)",
      "Bash(~/.agents/scripts/agent-fanout*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git branch -D*)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(npm install *)",
      "Bash(pnpm add *)",
      "Bash(yarn add *)",
      "Bash(pip install *)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(nc *)",
      "Bash(sed -i*)",
      "Bash(awk -i*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(./secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.agents/scripts/statusline-worktree"
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
