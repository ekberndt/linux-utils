#!/usr/bin/env bash
# agent-fanout: create N git worktrees as siblings of the current repo and
# open a tmux session with one agent session per pane.
#
# Usage:
#   agent-fanout --codex         # 6 worktrees, run codex in each pane
#   agent-fanout --claude -n 4   # run claude in 4 panes
#   agent-fanout -p myprefix     # branches myprefix/wt1..N
#   agent-fanout -s mysession    # tmux session name
#
# Agent flags:
#   --codex runs codex
#   --claude runs claude
# Worktree layout: <parent>/<repo>_wt/<repo>_wt<i>  (sibling folder beside the repo)

set -euo pipefail

N=6
PREFIX="feat"
SESSION=""
AGENT_CMD=""
AGENT_SELECTOR=""

set_agent_cmd() {
  local selector="$1"
  local command="$2"

  if [[ -n "$AGENT_SELECTOR" && "$AGENT_SELECTOR" != "$selector" ]]; then
    echo "error: choose only one agent selector (--codex or --claude)" >&2
    exit 2
  fi

  AGENT_SELECTOR="$selector"
  AGENT_CMD="$command"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --codex)
      set_agent_cmd "codex" "codex"
      shift
      ;;
    --claude)
      set_agent_cmd "claude" "claude"
      shift
      ;;
    -n|--count)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires a count" >&2
        exit 2
      fi
      N="$2"
      shift 2
      ;;
    -p|--prefix)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires a branch prefix" >&2
        exit 2
      fi
      PREFIX="$2"
      shift 2
      ;;
    -s|--session)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires a tmux session name" >&2
        exit 2
      fi
      SESSION="$2"
      shift 2
      ;;
    -h|--help)
      sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      exit 2
      ;;
    *)
      echo "error: unexpected argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$AGENT_CMD" ]]; then
  echo "error: choose an agent selector (--codex or --claude)" >&2
  exit 2
fi

if ! [[ "$N" =~ ^[1-9][0-9]?$ ]] || (( N < 1 || N > 16 )); then
  echo "error: -n must be 1..16 (got '$N')" >&2
  exit 2
fi

command -v tmux >/dev/null || { echo "error: tmux not installed" >&2; exit 1; }
command -v git  >/dev/null || { echo "error: git not installed"  >&2; exit 1; }
AGENT_BIN="${AGENT_CMD%% *}"
command -v "$AGENT_BIN" >/dev/null || { echo "error: agent command not found: $AGENT_BIN" >&2; exit 1; }

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "error: not inside a git repository" >&2
  exit 1
}
REPO_NAME="$(basename "$REPO_ROOT")"
PARENT_DIR="$(dirname "$REPO_ROOT")"

# Default session to fanout-<repo> so distinct repos get distinct tmux sessions.
# tmux session names cannot contain '.' or ':'; sanitize them.
if [[ -z "$SESSION" ]]; then
  SESSION="fanout-$(echo "$REPO_NAME" | tr '.:' '__')"
fi

# Pick a base ref: prefer origin/HEAD, then main, then master, else current HEAD.
BASE_REF=""
if git -C "$REPO_ROOT" symbolic-ref --quiet refs/remotes/origin/HEAD >/dev/null 2>&1; then
  BASE_REF="$(git -C "$REPO_ROOT" symbolic-ref --short refs/remotes/origin/HEAD)"
elif git -C "$REPO_ROOT" show-ref --verify --quiet refs/heads/main; then
  BASE_REF="main"
elif git -C "$REPO_ROOT" show-ref --verify --quiet refs/heads/master; then
  BASE_REF="master"
else
  BASE_REF="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
fi

WT_PARENT="${PARENT_DIR}/${REPO_NAME}_wt"
mkdir -p "$WT_PARENT"

echo "repo:      $REPO_ROOT"
echo "base ref:  $BASE_REF"
echo "worktrees: $N in '${WT_PARENT}/' (branch prefix '${PREFIX}/wt')"
echo "session:   $SESSION"
echo "agent:     $AGENT_CMD"
echo

WT_PATHS=()
for i in $(seq 1 "$N"); do
  WT_PATH="${WT_PARENT}/${REPO_NAME}_wt${i}"
  BRANCH="${PREFIX}/wt${i}"
  WT_PATHS+=("$WT_PATH")

  if [[ -d "$WT_PATH" ]]; then
    echo "exists:  $WT_PATH"
    continue
  fi

  if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/${BRANCH}"; then
    git -C "$REPO_ROOT" worktree add "$WT_PATH" "$BRANCH" >/dev/null
    echo "reused:  $WT_PATH  ($BRANCH)"
  else
    git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WT_PATH" "$BASE_REF" >/dev/null
    echo "created: $WT_PATH  ($BRANCH from $BASE_REF)"
  fi
done

SSH_HOST="${AGENT_FANOUT_SSH_HOST:-$(hostname -s 2>/dev/null || hostname)}"
if [[ -n "${SSH_CONNECTION:-}${SSH_TTY:-}" ]]; then
  echo
  echo "# Run on your local machine to open VS Code Remote-SSH windows:"
  for WT in "${WT_PATHS[@]}"; do
    echo "code --folder-uri \"vscode-remote://ssh-remote+${SSH_HOST}${WT}\""
  done
  echo
  echo "(attaching tmux in 5s - copy the commands above now)" >&2
  sleep 5
elif command -v code >/dev/null; then
  for WT in "${WT_PATHS[@]}"; do
    code -n "$WT" >/dev/null 2>&1 || code "$WT" >/dev/null 2>&1 || true
  done
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo
  echo "tmux session '$SESSION' already exists; attaching." >&2
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    exec tmux attach -t "$SESSION"
  fi
  exit 0
fi

tmux new-session -d -s "$SESSION" -n grid -c "${WT_PATHS[0]}"
for i in $(seq 1 $((N - 1))); do
  tmux split-window -t "${SESSION}:grid" -c "${WT_PATHS[$i]}"
  tmux select-layout -t "${SESSION}:grid" tiled >/dev/null
done
tmux select-layout -t "${SESSION}:grid" tiled >/dev/null

mapfile -t PANE_IDS < <(tmux list-panes -t "${SESSION}:grid" -F '#{pane_id}')
for i in "${!PANE_IDS[@]}"; do
  tmux send-keys -t "${PANE_IDS[$i]}" "$AGENT_CMD" Enter
done
tmux select-pane -t "${PANE_IDS[0]}"

if [[ -n "${TMUX:-}" ]]; then
  tmux switch-client -t "$SESSION"
else
  exec tmux attach -t "$SESSION"
fi
