#!/usr/bin/env python3

import os
import sys
import tempfile
from datetime import datetime
from pathlib import Path


def script_root() -> Path:
    return Path(__file__).resolve().parent.parent


def read_lines(path: Path) -> list[str]:
    if not path.exists():
        return []
    return path.read_text().splitlines()


def key_name(line: str) -> str | None:
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or stripped.startswith("["):
        return None
    if "=" not in stripped:
        return None
    return stripped.split("=", 1)[0].strip()


def table_name(line: str) -> str | None:
    stripped = line.strip()
    if not stripped.startswith("["):
        return None
    return stripped.split("#", 1)[0].strip()


def keys_in_lines(lines: list[str]) -> set[str]:
    keys = set()
    for line in lines:
        key = key_name(line)
        if key:
            keys.add(key)
    return keys


def split_config(lines: list[str]) -> tuple[list[str], list[list[str]]]:
    root_lines = []
    table_sections = []
    current_table = None

    for line in lines:
        if table_name(line):
            if current_table is not None:
                table_sections.append(current_table)
            current_table = [line]
            continue

        if current_table is None:
            root_lines.append(line)
        else:
            current_table.append(line)

    if current_table is not None:
        table_sections.append(current_table)

    return root_lines, table_sections


def strip_blank_edges(lines: list[str]) -> list[str]:
    start = 0
    end = len(lines)

    while start < end and lines[start].strip() == "":
        start += 1
    while end > start and lines[end - 1].strip() == "":
        end -= 1

    return lines[start:end]


def filter_target(
    lines: list[str],
    root_keys: set[str],
    source_table_keys: dict[str, set[str]],
) -> tuple[list[str], dict[str, list[str]], list[list[str]]]:
    root_lines, table_sections = split_config(lines)
    filtered_root = []
    preserved_table_bodies = {}
    target_tables = []

    for line in root_lines:
        key = key_name(line)
        if key in root_keys:
            continue
        filtered_root.append(line)

    for section in table_sections:
        if not section:
            continue

        name = table_name(section[0])
        if name in source_table_keys:
            body = [
                line
                for line in section[1:]
                if key_name(line) not in source_table_keys[name]
            ]
            body = strip_blank_edges(body)
            if body:
                preserved_table_bodies[name] = body
            continue

        target_tables.append(strip_blank_edges(section))

    return strip_blank_edges(filtered_root), preserved_table_bodies, target_tables


def render(
    source_root: list[str],
    source_tables: list[list[str]],
    target_root: list[str],
    preserved_table_bodies: dict[str, list[str]],
    target_tables: list[list[str]],
) -> str:
    chunks: list[list[str]] = []

    source_root = strip_blank_edges(source_root)
    if source_root:
        chunks.append(source_root)

    if target_root:
        chunks.append(target_root)

    for section in source_tables:
        stripped = strip_blank_edges(section)
        if not stripped:
            continue

        name = table_name(stripped[0])
        chunk = stripped[:]

        if name in preserved_table_bodies:
            chunk.extend(preserved_table_bodies[name])

        chunks.append(chunk)

    for table in target_tables:
        if table:
            chunks.append(table)

    return "\n\n".join("\n".join(chunk) for chunk in chunks if chunk) + "\n"


def atomic_write(path: Path, content: str, original: str | None) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)

    if original is not None:
        stamp = os.environ.get("TIMESTAMP") or datetime.now().strftime("%Y%m%d-%H%M%S")
        backup = path.with_name(f"{path.name}.bak.{stamp}")
        backup.write_text(original)
        print(f"backed up existing config: {backup}")

    with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False) as tmp:
        tmp.write(content)
        tmp_path = Path(tmp.name)

    os.replace(tmp_path, path)


def needs_detach(target: Path, source: Path) -> bool:
    if target.is_symlink():
        return True
    try:
        return target.exists() and source.exists() and os.path.samefile(target, source)
    except OSError:
        return False


def main() -> int:
    repo_root = script_root()
    source = Path(sys.argv[1]) if len(sys.argv) > 1 else repo_root / "codex" / "config.toml"
    target = (
        Path(sys.argv[2])
        if len(sys.argv) > 2
        else Path(os.environ.get("CODEX_CONFIG_DIR", Path.home() / ".codex")) / "config.toml"
    )

    if not source.exists():
        print(f"missing source config: {source}", file=sys.stderr)
        return 1

    source_lines = read_lines(source)
    target_original = target.read_text() if target.exists() else None
    target_lines = target_original.splitlines() if target_original else []

    source_root, source_tables = split_config(source_lines)
    root_keys = keys_in_lines(source_root)
    source_table_keys = {
        name: keys_in_lines(section[1:])
        for section in source_tables
        if (name := table_name(section[0]))
    }
    target_root, preserved_table_bodies, target_tables = filter_target(
        target_lines,
        root_keys,
        source_table_keys,
    )
    rendered = render(source_root, source_tables, target_root, preserved_table_bodies, target_tables)

    must_detach = needs_detach(target, source)

    if target_original == rendered and not must_detach:
        print(f"already current: {target}")
        return 0

    if os.environ.get("DRY_RUN") == "true":
        action = "would detach + update" if must_detach else "would update" if target.exists() else "would create"
        print(f"{action}: {target}")
        return 0

    atomic_write(target, rendered, target_original)
    print(f"injected Codex config: {target}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
